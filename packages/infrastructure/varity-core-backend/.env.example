# ====================================
# Varity Generic Template Environment Variables
# ====================================

# ============ Deployer Wallet ============
# Private key for contract deployment (NEVER commit actual private key!)
PRIVATE_KEY=your_private_key_here

# ============ RPC Endpoints ============
# Arbitrum Sepolia (L2 Testnet) - Primary testnet
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Arbitrum One (L2 Mainnet) - For production
ARBITRUM_ONE_RPC_URL=https://arb1.arbitrum.io/rpc

# Ethereum Sepolia (L1 Testnet) - For L1<->L2 bridge testing
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY

# Ethereum Mainnet (L1 Mainnet) - For production L1<->L2 bridge
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_API_KEY

# ============ API Keys ============
# Infura (for Ethereum RPC)
INFURA_API_KEY=your_infura_api_key_here

# Etherscan (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Arbiscan (for Arbitrum contract verification)
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# CoinMarketCap (for gas reporting)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# ============ Gas Reporting ============
# Set to "true" to enable gas reporting
REPORT_GAS=false

# ============ DePin Integration (Future) ============
# Akash Network
AKASH_RPC_URL=https://rpc.akashnet.net:443
AKASH_MNEMONIC=your_akash_mnemonic_here

# Filecoin/IPFS
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here
LIGHTHOUSE_API_KEY=your_lighthouse_api_key_here

# Celestia DA
CELESTIA_RPC_URL=https://rpc.celestia.pops.one
CELESTIA_AUTH_TOKEN=your_celestia_auth_token_here

# Lit Protocol
LIT_PROTOCOL_NETWORK=cayenne # Use "cayenne" for testnet, "habanero" for mainnet

# ============ Company Configuration ============
# Default company configuration for deployment
COMPANY_ID=varity-iso-demo
COMPANY_NAME=Varity ISO Demo Company
INDUSTRY=iso
ENTITY_TYPE=merchant
MANAGER_TYPE=rep
TRANSACTION_TYPE=payment
TEMPLATE_VERSION=v1.0.0

# ============ Testing ============
# Test wallet private keys (for local testing only)
TEST_PRIVATE_KEY_1=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TEST_PRIVATE_KEY_2=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
TEST_PRIVATE_KEY_3=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# ============ Frontend Integration ============
# Contract addresses (populated after deployment)
ACCESS_CONTROL_REGISTRY_ADDRESS=
DATA_PROOF_REGISTRY_ADDRESS=
WALLET_FACTORY_ADDRESS=
PAYMASTER_ADDRESS=
GENERIC_TEMPLATE_ADDRESS=
