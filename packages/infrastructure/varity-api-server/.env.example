# Varity API Server Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_BASE_PATH=/api/v1

# Database Configuration (PostgreSQL)
# Local PostgreSQL: postgresql://user:password@localhost:5432/varity
# Akash PostgreSQL: postgresql://user:password@akash-postgres-url:5432/varity
DATABASE_URL=postgresql://varity:varity123@localhost:5432/varity_api

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# SIWE (Sign-In With Ethereum)
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3001
SIWE_STATEMENT=Sign in to Varity Dashboard

# Privy Authentication (Email/Social Login for Non-Crypto Users)
# Get credentials from Conduit Marketplace or https://dashboard.privy.io/
PRIVY_APP_ID=your-privy-app-id-here
PRIVY_APP_SECRET=your-privy-app-secret-here
PRIVY_VERIFICATION_KEY=your-privy-verification-key-here
ENABLE_PRIVY_AUTH=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STRICT_MAX_REQUESTS=10

# Backend SDK Configuration
BACKEND_SDK_TIMEOUT=30000

# Filecoin Storage (Pinata)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# Akash Network
AKASH_NODE_URL=https://rpc.akash.network
AKASH_CHAIN_ID=akashnet-2

# Arbitrum L3
ARBITRUM_L3_RPC_URL=http://localhost:8545
ARBITRUM_L3_CHAIN_ID=412346

# Celestia
CELESTIA_NODE_URL=http://localhost:26658
CELESTIA_NAMESPACE=varity

# Lit Protocol
LIT_NETWORK=jalapeno
LIT_CHAIN=ethereum

# Monitoring
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_TRACKING=true

# Security
HELMET_ENABLED=true
TRUST_PROXY=false
