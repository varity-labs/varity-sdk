{
  "name": "@varity-labs/client-js",
  "version": "2.0.0",
  "description": "Comprehensive JavaScript/TypeScript client library for Varity L3 blockchain - Powered by Thirdweb SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "example": "ts-node examples/basic-usage.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "varity",
    "blockchain",
    "web3",
    "thirdweb",
    "arbitrum",
    "l3",
    "wallet",
    "smart-contracts",
    "ipfs",
    "storage",
    "siwe",
    "usdc",
    "depin",
    "filecoin"
  ],
  "author": "Varity",
  "license": "MIT",
  "dependencies": {
    "thirdweb": "^5.112.0",
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.48",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "react": "^18.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/varity-labs/varity-sdk"
  },
  "bugs": {
    "url": "https://github.com/varity-labs/varity-sdk/issues"
  },
  "sideEffects": false
}
