{
  "name": "@varity-labs/types",
  "version": "2.0.0-beta.1",
  "description": "Type definitions for Varity SDK — auth, database, API, and utility types",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["varity", "types", "typescript", "sdk", "developer-tools", "react", "nextjs"],
  "author": "Varity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/varity-labs/varity-sdk.git",
    "directory": "packages/core/varity-types"
  },
  "homepage": "https://docs.varity.so",
  "bugs": {
    "url": "https://github.com/varity-labs/varity-sdk/issues"
  },
  "optionalDependencies": {
    "thirdweb": "^5.112.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
