{
  "name": "@varity-labs/sdk",
  "version": "2.0.0-alpha.1",
  "description": "Varity SDK - Build any app on Varity L3 with complete thirdweb integration (Engine, Nebula AI, Storage, Bridge, Gateway, x402)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "bin": {
    "varity": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "cli:dev": "npm run build && node dist/cli/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "varity",
    "varity-l3",
    "thirdweb",
    "multi-chain",
    "web3",
    "blockchain",
    "erc-4337",
    "account-abstraction",
    "gasless-transactions",
    "depin",
    "arbitrum",
    "base",
    "ipfs",
    "arweave",
    "cross-chain",
    "ai-blockchain",
    "nebula-ai"
  ],
  "author": "Varity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/varity/varity-sdk"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@mui/x-date-pickers": "^6.19.0",
    "@varity-labs/types": "workspace:*",
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "ethers": "^6.0.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.2.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "thirdweb": "^5.112.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
