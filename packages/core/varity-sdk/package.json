{
  "name": "@varity-labs/sdk",
  "version": "2.0.0-beta.2",
  "description": "Varity SDK - Build, deploy, and monetize applications with auth, database, storage, and analytics",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chains": {
      "types": "./dist/chains/index.d.ts",
      "default": "./dist/chains/index.js"
    },
    "./blockchain": {
      "types": "./dist/blockchain/index.d.ts",
      "default": "./dist/blockchain/index.js"
    },
    "./thirdweb": {
      "types": "./dist/thirdweb/index.d.ts",
      "default": "./dist/thirdweb/index.js"
    },
    "./tracking": {
      "types": "./dist/tracking/index.d.ts",
      "default": "./dist/tracking/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    },
    "./aa": {
      "types": "./dist/aa/index.d.ts",
      "default": "./dist/aa/index.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration/index.d.ts",
      "default": "./dist/orchestration/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/orchestration/catalog/chains/*.yaml",
    "src/orchestration/catalog/providers/**/*.yaml",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "cli:dev": "npm run build && node dist/cli/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "varity",
    "sdk",
    "deploy",
    "auth",
    "database",
    "storage",
    "analytics",
    "payments",
    "saas",
    "app-development"
  ],
  "author": "Varity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/varity-labs/varity-sdk.git",
    "directory": "packages/core/varity-sdk"
  },
  "homepage": "https://docs.varity.so",
  "bugs": {
    "url": "https://github.com/varity-labs/varity-sdk/issues"
  },
  "dependencies": {
    "@varity-labs/types": "workspace:^"
  },
  "optionalDependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@mui/x-date-pickers": "^6.19.0",
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^11.1.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "ethers": "^6.0.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.2.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "thirdweb": "^5.112.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "permissionless": "^0.2.57",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "viem": "^2.44.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "permissionless": "^0.2.0",
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    },
    "permissionless": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
