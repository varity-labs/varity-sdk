# Server Configuration
PORT=8080
NODE_ENV=development
DEBUG=true

# CORS Configuration
CORS_ORIGIN=*

# Pinata (Filecoin/IPFS) Configuration
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Varity Storage Configuration
LIT_PROTOCOL_ENABLED=false
CELESTIA_DA_ENABLED=false

# Google Service Account (Optional)
# For service account authentication, provide JSON as string
# GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# OAuth2 Configuration (Optional)
# If using OAuth2 authentication, tokens will be verified against Google

# ==================== WEB3 WALLET AUTHENTICATION ====================

# Authentication Mode
# Options: oauth, wallet, hybrid
# - oauth: Google OAuth2 only (traditional cloud authentication)
# - wallet: Web3 wallet signatures only (decentralized authentication)
# - hybrid: Accept both OAuth2 and wallet authentication (recommended)
AUTH_MODE=hybrid

# Wallet Authentication
# Enable/disable wallet-based authentication
WALLET_AUTH_ENABLED=true

# Thirdweb Configuration
# Client ID for Thirdweb SDK
THIRDWEB_CLIENT_ID=acb17e07e34ab2b8317aa40cbb1b5e1d

# JWT Configuration
# Secret key for signing JWT tokens (generate a secure random string)
JWT_SECRET=your-secure-jwt-secret-key-here

# JWT expiration time (default: 24h)
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRES_IN=24h

# Varity L3 Chain ID
VARITY_L3_CHAIN_ID=33529

# ==================== WALLET-TO-GCS PERMISSION MAPPING ====================

# GCS Wallet Bucket Mapping (JSON array)
# Maps wallet addresses to bucket permissions and storage layers
# Example customer permissions (replace with actual wallet addresses):
# GCS_WALLET_BUCKET_MAPPING='[{"address":"0x742d35Cc6634C0532925a3b844Bc454e4438f44e","buckets":[{"name":"customer-test-*","permissions":["read","write","delete"],"storageLayer":"customer-data"},{"name":"industry-iso-merchant-rag-*","permissions":["read"],"storageLayer":"industry-rag"}],"globalPermissions":[],"industry":"iso-merchant","customerId":"test","isAdmin":false}]'
