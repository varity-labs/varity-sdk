{
  "name": "@varity/migrate",
  "version": "1.0.0",
  "description": "CLI tool for migrating data from AWS S3 or Google Cloud Storage to Varity",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "varity-migrate": "./bin/varity-migrate"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "varity",
    "migration",
    "aws-s3",
    "gcs",
    "blockchain",
    "depin",
    "filecoin"
  ],
  "author": "Varity Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@google-cloud/storage": "^7.7.0",
    "@varity-labs/types": "workspace:*",
    "axios": "^1.6.5",
    "better-sqlite3": "^9.2.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "crypto": "^1.0.1",
    "ethers": "^6.15.0",
    "ipfs-http-client": "^60.0.1",
    "ora": "^5.4.1",
    "thirdweb": "^5.112.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cli-progress": "^3.11.5",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.7",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "aws-sdk-client-mock": "^3.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
