# Varity S3 Gateway Configuration

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ===== AUTHENTICATION CONFIGURATION =====

# Authentication Mode: iam | wallet | hybrid (default: hybrid)
# - iam: Only AWS IAM authentication
# - wallet: Only Web3 wallet authentication
# - hybrid: Both IAM and wallet authentication supported
AUTH_MODE=hybrid

# Wallet Authentication (Web3)
WALLET_AUTH_ENABLED=true
JWT_SECRET=your-secure-jwt-secret-key-here
JWT_EXPIRY=24h

# Thirdweb Configuration (for Web3 integration)
THIRDWEB_CLIENT_ID=a35636133eb5ec6f30eb9f4c15fce2f3

# Varity L3 Chain Configuration
VARITY_CHAIN_ID=33529

# AWS Credentials (for IAM authentication)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ===== VARITY SDK CONFIGURATION =====

# Varity Network
VARITY_NETWORK=arbitrum-sepolia
VARITY_API_KEY=your-varity-api-key

# Storage Backend Configuration
STORAGE_BACKEND=filecoin-ipfs
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# ===== SECURITY CONFIGURATION =====

# CORS Configuration
CORS_ORIGIN=*

# File Upload Limits
MAX_UPLOAD_SIZE=100mb

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
