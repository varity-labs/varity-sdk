{
  "name": "@varity/s3-gateway",
  "version": "1.0.0",
  "description": "S3-compatible gateway for Varity storage - drop-in replacement for AWS S3",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "s3",
    "gateway",
    "filecoin",
    "ipfs",
    "varity",
    "decentralized-storage"
  ],
  "author": "Varity",
  "license": "MIT",
  "dependencies": {
    "@varity-labs/sdk": "workspace:*",
    "@varity-labs/types": "workspace:*",
    "aws4": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.13.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "siwe": "^2.3.2",
    "thirdweb": "^5.112.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/supertest": "^2.0.16",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
