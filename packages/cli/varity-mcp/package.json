    "copilot",
    "windsurf",
    "chatgpt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/varity-labs/varity-sdk.git",
    "directory": "packages/cli/varity-mcp"
  },
  "homepage": "https://docs.varity.so/ai-tools/mcp-server-spec",
  "bugs": {
    "url": "https://github.com/varity-labs/varity-mcp/issues"
  },
  "author": "Varity Labs <team@varity.so>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sentry/node": "^10.43.0",
