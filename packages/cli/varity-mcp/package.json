{
  "name": "@varity-labs/mcp",
  "version": "1.3.0",
  "description": "Varity MCP Server — build, deploy, and monetize apps from any AI coding tool in 60 seconds",
  "type": "module",
  "bin": {
    "varity-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
