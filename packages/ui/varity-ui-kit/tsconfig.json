{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react",
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "src/core/VarityClient.ts",
    "src/hooks/useVarityAPI.tsx",
    "src/types/api-extensions.ts",
    "src/web3/**/*",
    "src/hooks/web3/**/*",
    "src/providers/VarityProvider.tsx",
    "src/providers/WalletContext.tsx",
    "src/providers/ChainContext.tsx",
    "src/wallets/SimpleSmartWallet.tsx",
    "src/wallets/SmartWalletProvider.tsx",
    "src/wallets/index.ts",
    "src/components/InAppWallet/**/*",
    "src/components/SIWE/**/*",
    "src/components/Onramp/**/*",
    "src/providers/index.ts"
  ]
}
