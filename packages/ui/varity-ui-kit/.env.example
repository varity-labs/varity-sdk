# Varity UI Kit Environment Configuration

# ============================================
# PRIVY CONFIGURATION (Non-Crypto Users)
# ============================================
# Get your Privy App ID from Conduit Marketplace or https://dashboard.privy.io/
# Privy enables email/social login without requiring MetaMask or crypto wallets
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# Privy App Secret (Backend only - DO NOT expose to frontend)
PRIVY_APP_SECRET=your-privy-app-secret-here

# Privy Verification Key (for JWT verification)
PRIVY_VERIFICATION_KEY=your-privy-verification-key-here

# ============================================
# THIRDWEB CONFIGURATION
# ============================================
# Thirdweb Client ID for Web3 functionality
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=a35636133eb5ec6f30eb9f4c15fce2f3

# Thirdweb Secret Key (Backend only)
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key-here

# ============================================
# VARITY L3 CHAIN CONFIGURATION
# ============================================
# Varity L3 Testnet RPC URL
NEXT_PUBLIC_VARITY_RPC_URL=https://rpc-varity-testnet-rroe52pwjp.t.conduit.xyz

# Varity L3 Chain ID
NEXT_PUBLIC_VARITY_CHAIN_ID=33529

# Varity L3 Explorer URL
NEXT_PUBLIC_VARITY_EXPLORER_URL=https://explorer-varity-testnet-rroe52pwjp.t.conduit.xyz

# ============================================
# VARITY API CONFIGURATION
# ============================================
# Varity Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# API Timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# ============================================
# ZERODEV CONFIGURATION (Account Abstraction)
# ============================================
# ZeroDev Project ID (for gasless transactions)
NEXT_PUBLIC_ZERODEV_PROJECT_ID=your-zerodev-project-id-here

# ZeroDev Bundler URL
NEXT_PUBLIC_ZERODEV_BUNDLER_URL=https://rpc.zerodev.app/api/v2/bundler/YOUR_PROJECT_ID

# ZeroDev Paymaster URL (for gas sponsorship)
NEXT_PUBLIC_ZERODEV_PAYMASTER_URL=https://rpc.zerodev.app/api/v2/paymaster/YOUR_PROJECT_ID

# ============================================
# DECENT CONFIGURATION (Cross-Chain Bridging)
# ============================================
# Decent API Key (for cross-chain payments)
NEXT_PUBLIC_DECENT_API_KEY=your-decent-api-key-here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Application Environment
NODE_ENV=development

# Application Name
NEXT_PUBLIC_APP_NAME=Varity Dashboard

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/Disable Features
NEXT_PUBLIC_ENABLE_PRIVY_AUTH=true
NEXT_PUBLIC_ENABLE_SIWE_AUTH=true
NEXT_PUBLIC_ENABLE_ZERODEV=false
NEXT_PUBLIC_ENABLE_DECENT=false

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics ID (optional)
NEXT_PUBLIC_GA_ID=

# Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# NOTES
# ============================================
# - All NEXT_PUBLIC_* variables are exposed to the browser
# - Never commit actual API keys to version control
# - Use different values for development, staging, and production
# - Get Privy credentials from: https://dashboard.privy.io/
# - Get ZeroDev credentials from: https://dashboard.zerodev.app/
# - Get Decent credentials from: https://decent.xyz/
