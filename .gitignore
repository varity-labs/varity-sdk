# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# Build artifacts in source (should not be committed)
**/*.d.ts.map
**/*.js.map
**/src/**/*.d.ts
**/src/**/*.js
!**/src/**/*.config.js
!**/postcss.config.js
!**/tailwind.config.js
!**/jest.config.cjs
!**/next.config.js
!**/hardhat.config.js

# Testing
coverage/
.nyc_output/
test-results/
htmlcov/
.coverage
*.egg-info/

# Environment (NEVER commit .env files)
.env
.env.local
.env.*.local
.env.production
.env.development
.pypirc

# Private keys / sensitive config (use .example files instead)
**/network.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
