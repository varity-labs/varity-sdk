# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# Build artifacts in source (should not be committed)
**/*.d.ts.map
**/*.js.map
**/src/**/*.d.ts
**/src/**/*.js
!**/src/**/*.config.js
!**/postcss.config.js
!**/tailwind.config.js
!**/jest.config.cjs
!**/next.config.js
!**/hardhat.config.js

# Testing
coverage/
.nyc_output/
test-results/
htmlcov/
.coverage
*.egg-info/

# Environment (NEVER commit .env files)
.env
.env.local
.env.*.local
.env.production
.env.development
.pypirc

# Private keys / sensitive config (use .example files instead)
**/network.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Generated / Solidity
typechain-types/
artifacts/
/cache/
compile-warnings.txt
compile_output.txt
final-compilation.txt

# Database
*.db
*.sqlite

# Package manager locks (only keep pnpm-lock.yaml at root)
packages/**/package-lock.json
packages/**/yarn.lock

# Apps folder (separate repos)
apps/

# Services (deployed separately)
services/*
!services/varity-gateway/
!services/varity-db-proxy/
!services/varity-credential-proxy/
!services/billing-meter/

# Tools (separate repos — root level only)
/tools/

# Examples (cleanup later)
examples/



# Claude session files
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Temporary files
*.backup
*.bak
*.tmp
.cursor/
cli/varitykit_old/
services/akash-mcp/

