yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Generated / Solidity
typechain-types/
artifacts/
cache/
compile-warnings.txt
compile_output.txt
final-compilation.txt

# Database
*.db
*.sqlite

# Package manager locks (only keep pnpm-lock.yaml at root)
packages/**/package-lock.json
packages/**/yarn.lock

# Apps folder (separate repos)
apps/

# Services (deployed separately)
services/*
!services/varity-gateway/
!services/varity-db-proxy/
!services/varity-credential-proxy/

# Tools (separate repos)
tools/

# Examples (cleanup later)
examples/

# Non-MVP packages (kept locally, hidden from public repo)
packages/clients/
packages/infrastructure/
packages/migration/

# Claude session files
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Temporary files
*.backup
*.bak
*.tmp
.cursor/
cli/varitykit_old/
services/akash-mcp/

