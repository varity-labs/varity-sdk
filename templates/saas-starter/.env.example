# Varity Configuration
# Leave blank for development — shared dev credentials are used automatically.
# For production, get your credentials from: https://developer.store.varity.so

NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# Your Varity App ID (required for payments)
# You'll receive this after running: varietykit app deploy --submit-to-store
NEXT_PUBLIC_VARITY_APP_ID=
