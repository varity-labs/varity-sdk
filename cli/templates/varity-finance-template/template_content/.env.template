# Varity API Configuration
VITE_VARITY_API_URL={{ varity_api_url }}
VITE_VARITY_API_KEY=your_api_key_here
VITE_VARITY_CHAIN_ID={{ varity_chain_id }}

# RAG Configuration
VITE_RAG_NAMESPACE={{ industry_rag_namespace }}

# Branding
VITE_PRIMARY_COLOR={{ primary_color }}
VITE_SECONDARY_COLOR={{ secondary_color }}
VITE_COMPANY_NAME={{ company_name }}
VITE_LOGO_URL={{ logo_url }}

# Features
{% if enable_fraud_detection %}
VITE_ENABLE_FRAUD_DETECTION=true
{% endif %}
{% if enable_aml_monitoring %}
VITE_ENABLE_AML_MONITORING=true
{% endif %}
{% if enable_risk_forecasting %}
VITE_ENABLE_RISK_FORECASTING=true
{% endif %}

# Development
VITE_ENABLE_MOCK_DATA={{ include_mock_data | lower }}
VITE_DEBUG_MODE=false
