# VarityKit Smart Contract Deployment Configuration
# Copy this file to .env and fill in your values

# ========== DEPLOYER WALLET ==========
# Private key for deploying contracts (DO NOT COMMIT THIS!)
# Generate with: npx hardhat vars set DEPLOYER_PRIVATE_KEY
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ========== VARITY L3 CONFIGURATION ==========
# Varity L3 RPC URL (provided by Varity DevOps team)
VARITY_L3_RPC_URL=http://localhost:8545

# Varity L3 Chain ID (placeholder, will be provided)
VARITY_L3_CHAIN_ID=42161000

# Varity L3 Block Explorer (for contract verification)
VARITY_L3_EXPLORER_URL=http://localhost:4000
VARITY_L3_EXPLORER_API=http://localhost:4000/api

# ========== ARBITRUM SEPOLIA TESTNET ==========
# Arbitrum Sepolia RPC URL (for testing before Varity L3 deployment)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API Key (for contract verification on Arbitrum)
# Get from: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# ========== GAS REPORTING ==========
# Enable gas reporting
REPORT_GAS=false

# CoinMarketCap API Key (for USD gas cost estimates)
# Get from: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# ========== FORKING (OPTIONAL) ==========
# Fork Arbitrum mainnet for local testing
FORK_MAINNET=false

# ========== DEPLOYMENT CONFIGURATION ==========
# Platform owner address (receives platform fees)
PLATFORM_OWNER_ADDRESS=your_platform_owner_address_here

# Initial minimum quality score (85)
MIN_QUALITY_SCORE=85

# Platform fee percentage (70%)
PLATFORM_FEE_PERCENT=70

# Creator fee percentage (30%)
CREATOR_FEE_PERCENT=30
