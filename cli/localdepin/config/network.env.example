# LocalDePin Network Configuration
# This file contains environment variables for all services
#
# SETUP: Copy this file to network.env and fill in your values:
#   cp network.env.example network.env

# Network Settings
NETWORK_NAME=localdepin
CHAIN_ID=421614
BLOCK_TIME=2

# Arbitrum L3 Settings
ARBITRUM_RPC_URL=http://localhost:8547
ARBITRUM_WS_URL=ws://localhost:8548
ARBITRUM_CHAIN_ID=421614

# IPFS/Filecoin Settings
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8081
PINATA_API_URL=http://localhost:3002

# Akash Settings
AKASH_API_URL=http://localhost:3003
LLM_MODEL=gemini-2.5-flash-mock
COMPUTE_UNITS=1000

# Celestia Settings
CELESTIA_RPC_URL=http://localhost:26658
CELESTIA_GATEWAY_URL=http://localhost:26659
CELESTIA_NETWORK=private

# Database Settings
DATABASE_URL=postgresql://varity:your_password_here@localhost:5432/varity_indexer
POSTGRES_USER=varity
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=varity_indexer

# Redis Settings
REDIS_URL=redis://localhost:6379

# API Server Settings
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=debug

# Explorer Settings
EXPLORER_PORT=8080
VITE_API_URL=http://localhost:3001
VITE_NETWORK=localdepin

# Development Settings
NODE_ENV=development
DEBUG=true
ENABLE_CORS=true

# Test Account (Developer Account 1)
# WARNING: Never use real private keys here. For local testing only.
TEST_PRIVATE_KEY=0x_YOUR_TEST_PRIVATE_KEY_HERE
TEST_ADDRESS=0x_YOUR_TEST_ADDRESS_HERE

# Admin Account
# WARNING: Never use real private keys here. For local testing only.
ADMIN_PRIVATE_KEY=0x_YOUR_ADMIN_PRIVATE_KEY_HERE
ADMIN_ADDRESS=0x_YOUR_ADMIN_ADDRESS_HERE
