{
  "name": "varity-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Build, deploy, and monetize production apps — auth, database, payments included. 70% cheaper than AWS.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.8.15",
    "typescript": "^5.3.0",
    "prettier": "^3.8.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/varity-labs/varity-sdk"
  },
  "license": "MIT",
  "keywords": [
    "varity",
    "sdk",
    "deploy",
    "saas",
    "auth",
    "database",
    "payments",
    "react",
    "nextjs",
    "developer-tools",
    "fullstack",
    "starter-template",
    "mcp",
    "model-context-protocol",
    "cursor",
    "claude",
    "ai",
    "vibe-coding"
  ],
  "homepage": "https://www.varity.so",
  "bugs": {
    "url": "https://github.com/varity-labs/varity-sdk/issues"
  },
  "author": "Varity"
