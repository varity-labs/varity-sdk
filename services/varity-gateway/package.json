{
  "name": "varity-gateway",
  "version": "1.9.16",
  "private": true,
  "license": "MIT",
  "description": "Custom domain gateway for Varity apps — maps varity.app/{name} to IPFS content",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "close-ghosts:dry": "tsx scripts/close-ghost-deployments.ts --dry-run",
    "close-ghosts": "tsx scripts/close-ghost-deployments.ts"
  },
  "dependencies": {
    "@akashnetwork/akash-api": "^1.4.0",
    "@akashnetwork/akashjs": "^0.11.1",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmjs/stargate": "^0.38.1",
    "@privy-io/node": "^0.16.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "4.20.0",
    "express-rate-limit": "^8.4.0",
    "node-cache": "^5.1.2",
    "sharp": "^0.34.5",
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "protobufjs": "7.5.5",
    "axios": ">=1.15.0"
  }
}
