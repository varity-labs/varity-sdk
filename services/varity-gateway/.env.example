# Varity Gateway — Environment Variables
# Copy to .env and fill in real values for local development.

# Server
NODE_ENV=development
PORT=8080

# DB Proxy connection (for domain resolution)
DB_PROXY_URL=http://localhost:5000
DB_PROXY_TOKEN=your-jwt-token-here

# Gateway authentication (CLI uses this to register domains)
GATEWAY_API_KEY=your-random-api-key-here

# Domain config
BASE_DOMAIN=varity.app
IPFS_BACKEND=ipfs.dweb.link
CACHE_TTL=300
